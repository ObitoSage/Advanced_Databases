# Copia este archivo a .env y ajusta los valores.
# cp .env.example .env   (o en PowerShell:  Copy-Item .env.example .env)

# ---- PostgreSQL ----
POSTGRES_USER=ecommerce
POSTGRES_PASSWORD=ecommerce_pass
POSTGRES_DB=ecommerce_db
POSTGRES_PORT=5432
POSTGRES_DATABASE_URL="postgresql://ecommerce:ecommerce_pass@localhost:5432/ecommerce_db?schema=public"

# ---- MongoDB ----
MONGO_PORT=27017
MONGO_DB=ecommerce_catalog
MONGO_DATABASE_URL="mongodb://localhost:27017/ecommerce_catalog?replicaSet=rs0&directConnection=true"

# ---- App ----
PORT=3000
NODE_ENV=development

# ---- Seguridad ----
JWT_SECRET=cambia_esto_por_un_secreto_largo_y_aleatorio
JWT_EXPIRES=1h
# Genera la clave con:
#   node -e "console.log(require('node:crypto').randomBytes(32).toString('hex'))"
CARD_ENCRYPTION_KEY=reemplaza_por_64_caracteres_hexadecimales
