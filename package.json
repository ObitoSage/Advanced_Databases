{
  "name": "ecommerce-poliglota",
  "version": "1.0.0",
  "description": "Backend e-commerce multitienda con Persistencia Políglota (PostgreSQL + MongoDB)",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "postinstall": "npm run prisma:generate",
    "db:up": "docker compose up -d",
    "db:down": "docker compose down",
    "db:logs": "docker compose logs -f",
    "prisma:generate:postgres": "prisma generate --schema=prisma/postgres/schema.prisma",
    "prisma:generate:mongo": "prisma generate --schema=prisma/mongo/schema.prisma",
    "prisma:generate": "npm run prisma:generate:postgres && npm run prisma:generate:mongo",
    "prisma:migrate": "prisma migrate dev --schema=prisma/postgres/schema.prisma",
    "prisma:push": "prisma db push --schema=prisma/mongo/schema.prisma",
    "prisma:studio:postgres": "prisma studio --schema=prisma/postgres/schema.prisma",
    "dev": "node --watch src/server.js",
    "start": "node src/server.js",
    "demo": "node src/demo.js",
    "demo:seguridad": "node src/test-seguridad.js",
    "test": "node --test --test-concurrency=1"
  },
  "dependencies": {
    "@prisma/client": "^6.4.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.2"
  },
  "devDependencies": {
    "prisma": "^6.4.0",
    "supertest": "^7.2.2"
  }
}
